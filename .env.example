# OpenClaw SaaS Platform - 环境变量配置
# 复制此文件为 .env 并修改相关配置

# 基础配置
DOMAIN=localhost
SAAS_SUBDOMAIN=saas
TENANT_SUBDOMAIN=tenant

# ACME (Let's Encrypt) 邮箱配置
ACME_EMAIL=admin@example.com

# JWT 密钥 (请修改为随机字符串)
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production

# Dokploy API Token
DOKPLOY_API_TOKEN=

# Traefik Dashboard 端口
TRAEFIK_DASHBOARD_PORT=9090

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# PostgreSQL 数据库配置
POSTGRES_USER=saas
POSTGRES_PASSWORD=saas_password_change_me
POSTGRES_DB=saas_openclaw

# 数据库资源限制
POSTGRES_CPU_LIMIT=2
POSTGRES_MEMORY_LIMIT=2G

# Redis 配置
REDIS_PASSWORD=redis_password_change_me
REDIS_MAX_MEMORY=256mb
REDIS_CPU_LIMIT=0.5
REDIS_MEMORY_LIMIT=512M

# SaaS 平台配置
SAAS_PLATFORM_PORT=8080

# Docker 网络配置
DOCKER_SUBNET=172.20.0.0/16
