# Docker Compose 环境变量配置
# 复制此文件为 .env 并修改相应值

# ============================================
# PostgreSQL 数据库配置
# ============================================
POSTGRES_DB=openclaw
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=your_secure_password_here

# ============================================
# 后端服务配置
# ============================================
SERVER_PORT=8080
DB_HOST=postgres
DB_PORT=5432
DB_NAME=openclaw
DB_USER=openclaw
DB_PASSWORD=your_secure_password_here
LOG_LEVEL=info

# ============================================
# 生产环境注意事项
# ============================================
# 1. 使用强密码替换 your_secure_password_here
# 2. 生产环境使用 Docker Secrets 管理敏感信息
# 3. 不要将 .env 文件提交到版本控制
