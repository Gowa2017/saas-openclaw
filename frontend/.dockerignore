# 前端 .dockerignore
# Story 1.5: Docker 容器化配置
# 用途: 减少构建上下文大小，排除不需要的文件

# ============================================
# 依赖目录
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================
# 构建产物
# ============================================
dist/
dist-ssr/
*.local

# ============================================
# 版本控制
# ============================================
.git
.gitignore
.gitattributes

# ============================================
# 文档
# ============================================
*.md
README.md
LICENSE
docs/

# ============================================
# 开发工具配置
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.eslintcache
.stylelintcache

# ============================================
# 测试文件
# ============================================
coverage/
.nyc_output/
__tests__/
*.test.ts
*.test.js
*.spec.ts
*.spec.js
jest.config.*
vitest.config.*
playwright.config.*
cypress/

# ============================================
# 环境配置（敏感信息）
# ============================================
.env
.env.local
.env.*.local
.env.production
.env.development

# ============================================
# Docker 相关
# ============================================
Dockerfile*
docker-compose*.yml
.docker/
.dockerignore

# ============================================
# 其他配置文件
# ============================================
.prettierrc*
.eslintrc*
.stylelintrc*
# tsconfig.json is required for build
# vite.config.ts is required for build
